{
  "_comment": "config.json สำหรับ PGP Benchmark — ออกแบบพอดีกับ VM 8 GB / 8 vCPU (ENVIRONMENT.md)",
  "_constraints": {
    "vm_ram_gb": 8,
    "vm_vcpu": 8,
    "tmpfs_corpus_gb": 2,
    "jvm_heap": "-Xmx3g",
    "memory_quota_per_runner_mb": 3072,
    "large_inmem_cap_mb": 256,
    "note": "ไฟล์ > 256 MB ต้องใช้ streaming (Req 15.4); quota เท่ากันทั้งสอง runner (ส่วนต่าง=0, Req 3.4)"
