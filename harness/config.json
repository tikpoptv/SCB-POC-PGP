  "rounds": 50,
  "warmupIterations": 5,
  "seed": 123456789,
  "samplingIntervalMs": 100,
  "resultDir": "./results",
  "corpusOnTmpfs": true,
  "stabilityThresholdCV": 0.05,
  "confidenceLevel": 0.95,
  "bestVariantCriterion": "p50_roundtrip",

  "cryptoProfiles": [
    {
      "id": "aes256-zlib",
      "pubAlg": "RSA-2048",
      "cipher": "AES-256",
      "compression": "ZLIB",
      "hash": "SHA-256"
    },
    {
      "id": "aes256-nocomp",
